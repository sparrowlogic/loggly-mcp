# Copy to .env (gitignored) and fill in. Load before running:
#   set -a && source .env && set +a
# Create an API token at: https://<subdomain>.loggly.com  → Source Setup > API Tokens.
# NOTE: this is a Loggly *API token*, not the ingestion/customer token.
LOGGLY_API_TOKEN=
# Account subdomain — selects the host https://<subdomain>.loggly.com
LOGGLY_SUBDOMAIN=
